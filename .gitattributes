# Normalize all text files to LF in the repo; force LF on checkout everywhere.
* text=auto eol=lf

*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.zip  binary
*.gz   binary
*.tgz  binary
*.zst  binary
*.tar  binary
